
printf( "Starting the ode test...\n" );

primes = function( t; x ) {
    local ( xdot );
    xdot = x[1]*(1-x[2]*x[2])-x[2], x[1];
    return xdot;
};

x = ode4( primes; 0; 20; 0,.25 );

if ( abs( x[1;x.nc] + 0.8224 ) > .001 ) {
    printf( "...failed.\a\n" );
    exception();
else
    printf( "...passed.\n" );
}
